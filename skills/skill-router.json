{
  "version": 2,
  "description": "Maps user intent keywords to OpenCode skill names for proactive loading",
  "default_skills": ["concise-filter", "task-orchestrator", "memory-search"],
  "conflict_resolution": "priority_highest_wins",
  "user_config_path": "~/.opencode/skill-router-overrides.json",
  "fallback": {
    "description": "When no trigger rule matches, consult this chain. Each level checks before falling through.",
    "levels": [
      {"check_env": "OPENCODE_SKILL_ROUTER_FALLBACK", "description": "Environment variable override — set to comma-separated skill names"},
      {"check_user_config": true, "description": "User config file at skill-router-overrides.json — 'fallback_skills' array"},
      {"use_defaults": true, "skills": ["concise-filter", "task-orchestrator"], "description": "Built-in defaults: concise-filter + task-orchestrator"}
    ]
  },
