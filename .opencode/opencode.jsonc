{
  // CortexStratum — OpenCode Integration Configuration
  // This file tells OpenCode how to connect and use the MCP server.
  // Copy to your project root or ~/.config/opencode/ for global use.

  "mcpServers": {
    "CortexStratum": {
      "name": "CortexStratum",
      "description": "176-tool MCP server (v0.5.1-dev): SQLite+FTS5 memory, trace system, skill routing, multi-modal AI. See root opencode.json for full config.",
      "command": "python",
      "args": ["scripts/tools-mcp-server.py"],
      "env": {}
    },
    "CortexStratum-permissive": {
      "name": "CortexStratum (permissive mode)",
      "description": "Same as CortexStratum but with all permission checks bypassed",
      "command": "python",
      "args": ["scripts/tools-mcp-server.py", "--permissive"],
      "env": {}
    },
    "CortexStratum-debug": {
      "name": "CortexStratum (debug mode)",
      "description": "Same as CortexStratum with verbose debug logging",
      "command": "python",
      "args": ["scripts/tools-mcp-server.py", "--debug"],
      "env": {}
    }
  },

  // Agent routing: which tools to load automatically at session start
  "tools": {
    "autoLoad": [
      "read_skill_router_match",
      "read_memory_status",
      "read_verifier_status",
      "read_xtrace_status"
    ]
  }
}
