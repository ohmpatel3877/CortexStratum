                      {
                          "status":  "active",
                          "id":  "dt-20260715-011",
                          "rationale":  "Need isolated execution without Docker or heavy dependencies. Temp directories provide filesystem isolation; static safety checks gate dangerous operations. Timeouts prevent runaway processes.",
                          "decision":  "Implement SandboxManager with temp-directory isolation, process timeout kill, static safety evaluation (blocklist-based), and execution logging. No Docker dependency.",
                          "alternatives":  null,
                          "superseded_by":  null,
                          "title":  "Build temp-directory sandbox for isolated code execution",
                          "files":  [
                                        "scripts/sandbox-manager.py",
                                        "scripts/sandbox-integration.ps1",
                                        "data/sandbox-log.json"
                                    ],
                          "category":  "architecture",
                          "consequences":  [
                                               "Fast sandbox creation (~50ms) vs Docker (seconds)",
                                               "No network isolation (intentional for web tooling)",
                                               "Safety is blocklist-based, not guarantee"
                                           ],
                          "context":  "",
                          "updated_at":  "2026-07-15T23:15:19Z",
