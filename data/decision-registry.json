                      {
                          "status":  "active",
                          "id":  "dt-20260715-009",
                          "title":  "Adopt Hybrid Triage-DAG orchestration pattern",
                          "rationale":  "LangGraph\u0027s DAG + Swarm\u0027s Triage Router pattern, mapped to OpenCode\u0027s task tool. Zero external deps, explicit state passing between subagents, pipeline composability.",
                          "superseded_by":  null,
                          "decision":  "Implement JSON-state DAG with OpenCode task tool as agent-as-tool primitive. DAG definitions in JSON, state files in .memory/dag-states/, coordinator resolves topological order and passes state between nodes.",
                          "consequences":  [
                                               "Subagents can now receive structured input from upstream nodes",
                                               "Enables multi-phase pipelines (research→implement→verify)",
                                               "Adds ~100ms per node for state file I/O",
                                               "Requires DAG definition JSON for every pipeline"
                                           ],
                          "alternatives":  null,
                          "created_at":  "2026-07-15T23:15:16Z",
                          "notes":  "",
