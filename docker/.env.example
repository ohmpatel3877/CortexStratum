# ─── patelserver Environment ──────────────────────────────────────
# Copy this to .env and fill in your values.
# You only need Docker installed — everything else runs in containers.

# ── mem0 Cloud Memory (required for cross-session persistence) ──
# Get a free API key: https://app.mem0.ai
MEM0_API_KEY=

# ── OpenCode Zen API (optional — connects to OpenCode cloud) ────
# Get an API key: https://opencode.ai
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_BASE_URL=https://api.opencode.ai
OPENCODE_HOST=patelserver
OPENCODE_DEPLOYMENT_ID=patelserver-docker

# ── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=info
