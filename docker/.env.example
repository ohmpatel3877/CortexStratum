# ─── opencode-container-server ────────────────────────────────────
# Copy this to .env and fill in your values as needed.
# Everything runs locally — no cloud services required.

# ── Local Memory ─────────────────────────────────────────────────
# The MCP server uses local SQLite+FTS5 memory search by default.
# No API keys needed — all data stays on your machine.

# ── OpenCode Zen API (optional — connects to OpenCode cloud) ────
# Get an API key: https://opencode.ai (optional — everything works without it)
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_BASE_URL=https://api.opencode.ai
OPENCODE_HOST=opencode-container
OPENCODE_DEPLOYMENT_ID=opencode-container-server

# ── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=info
