{
  "name": "cortex-stratum",
  "version": "1.0.0",
  "description": "78-tool MCP server: memory, trace, simulation, focus, agent orchestration. Pure Python stdlib.",
  "main": "index.js",
  "scripts": {
    "mem0:seed": "node scripts/seed-memories.js",
    "mem0:dream": "node scripts/consolidate.js",
    "mem0:status": "node scripts/check-status.js",
    "mem0:categories": "node scripts/set-categories.js"
  },
  "keywords": [
    "mem0",
    "memory",
    "ai-agent",
    "persistence"
  ],
  "license": "MIT",
  "author": {
    "name": "Ohm Patel",
    "url": "https://github.com/ohmpatel3877"
  },
  "type": "commonjs",
  "dependencies": {
    "opencode-mem": "^2.19.4"
  },
  "install": {
    "harnesses": ["opencode", "claude-code", "cursor"],
    "windows": "pwsh plugin-tools/install-cortex-stratum.ps1",
    "unix": "bash plugin-tools/install-cortex-stratum.sh",
    "docker": "docker compose up -d"
  },
  "mcpServers": {
    "cortex-stratum": {
      "name": "cortex-stratum",
      "description": "78-tool MCP server: xTrace, DTrace, Skill Router, Verifier, Goal Registry, multi-module AI generation",
      "command": "python",
      "args": ["scripts/tools-mcp-server.py"],
      "env": {}
    }
  }
}
